// to use the actual live product database configured by the "Product Management" (hanghoa.html) module.
(function syncProductsFromLocalStorage() {
  try {
    var saved = localStorage.getItem('hasu_global_products');
    if (saved) {
      var parsed = JSON.parse(saved);
      if (Array.isArray(parsed) && parsed.length > 0) {
        products.length = 0; // Clear the static array
        parsed.forEach(function (item) { products.push(item); });
        console.log('[HASU SYNC] Successfully loaded ' + parsed.length + ' real-time products from Product Management module.');
      }
    }
  } catch (e) {
    console.error('[HASU SYNC] Failed to synchronize cross-module products:', e);
  }
})();